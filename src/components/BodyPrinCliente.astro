<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
  rel="stylesheet"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
  rel="stylesheet"
/>
<!-- Leaflet CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<!-- Leaflet JS -->
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""></script>

<!--NUEVO CONTENEDOR DE TARJETAS -->
<div
  id="BodyPrinCliente"
  class="w-full min-h-screen bg-blue-50 font-display text-gray-800 pt-20"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div
      class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4"
    >
      <div>
        <h1
          class="text-3xl font-black text-gray-900 tracking-tight sm:text-4xl"
        >
          SERVICIOS DISPONIBLES
        </h1>
        <p class="mt-2 text-lg text-gray-500">
          Explora nuestros servicios disponibles y reserva tu próxima cita.
        </p>
      </div>
    </div>
    <div class="mb-8 flex flex-col sm:flex-row gap-4">
      <div class="relative flex-grow max-w-lg">
        <div
          class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
        >
          <span class="material-symbols-outlined text-gray-400">search</span>
        </div>
        <input
          id="input-busqueda"
          class="block w-full pl-10 pr-3 py-2.5 border border-gray-200 rounded-xl leading-5 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary sm:text-sm shadow-sm transition-shadow"
          placeholder="Buscar servicio o negocio..."
          type="text"
        />
      </div>
      <div
        class="flex items-center gap-2 overflow-x-auto pb-2 sm:pb-0 no-scrollbar"
      >
        <div class="h-6 w-px bg-gray-300 mx-1"></div>
        <button
          id="btn-todas-categorias"
          class="inline-flex items-center px-4 py-2.5 border border-transparent rounded-xl text-sm font-medium text-primary bg-primary/10 hover:bg-primary/20 transition-colors whitespace-nowrap"
        >
          Todas las categorias
        </button>
        <button
          id="btn-manicure"
          class="inline-flex items-center px-4 py-2.5 border border-transparent rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors whitespace-nowrap"
        >
          Manicure
        </button>
        <button
          id="btn-barberia"
          class="inline-flex items-center px-4 py-2.5 border border-transparent rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors whitespace-nowrap"
        >
          Barberia
        </button>
      </div>
    </div>

    <!-- spinner para esperar a que carge los servicios -->
    <div
      id="loader-servicios"
      class="align-center flex justify-center items-center h-48 w-full"
    >
      <span class="loader"></span>
    </div>

    <!-- aqui van las tarjetas de los servicios -->
    <div
      id="contenedor-servicios"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"
    >
      <!-- Generated by JS -->
    </div>

    <!-- paginacion -->
    <div class="flex items-center justify-between mt-6 px-2">
      <span class="text-sm text-gray-600 italic" id="info-paginacion"
        >Cargando...
      </span>
      <div class="flex items-center gap-2">
        <button
          id="btn-anterior"
          class="inline-flex items-center justify-center h-9 w-9 rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          <span class="material-symbols-outlined text-xl">chevron_left</span>
        </button>
        <button
          id="btn-siguiente"
          class="inline-flex items-center justify-center h-9 w-9 rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          <span class="material-symbols-outlined text-xl">chevron_right</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL DE MAPA -->
<div
  id="modal-mapa"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm hidden"
>
  <div
    class="bg-white w-full max-w-2xl rounded-3xl overflow-hidden shadow-2xl transform transition-all scale-95 opacity-0 duration-300"
    id="modal-mapa-content"
  >
    <div class="p-6 border-b border-gray-100 flex justify-between items-center">
      <div>
        <h3 id="modal-mapa-titulo" class="text-xl font-black text-slate-800">
          Ubicación del Negocio
        </h3>
        <p id="modal-mapa-direccion" class="text-sm text-slate-500"></p>
      </div>
      <button
        id="cerrar-modal-mapa"
        class="h-10 w-10 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-400 hover:text-gray-900 transition-colors"
      >
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <div id="contenedor-mapa-modal" class="h-96 w-full relative z-10"></div>
    <div
      class="p-6 bg-gray-50 flex flex-col sm:flex-row gap-4 items-center justify-between"
    >
      <div class="flex items-center gap-2 text-primary font-bold">
        <span class="material-symbols-outlined">info</span>
        <span class="text-xs">Usa Google Maps para navegar</span>
      </div>
      <a
        id="btn-google-maps"
        href="#"
        target="_blank"
        class="w-full sm:w-auto flex items-center justify-center gap-2 bg-slate-900 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-slate-800 transition-all shadow-lg active:scale-95"
      >
        <span class="material-symbols-outlined">map_search</span>
        Abrir en Google Maps
      </a>
    </div>
  </div>
</div>

<script src="../utils/BodyPrinClienteJs.js"></script>
