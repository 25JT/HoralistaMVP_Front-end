---
import "../styles/global.css";
---

<div
  id="modal-notificacion"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm hidden"
>
  <style>
    .material-symbols-outlined {
      font-variation-settings:
        "FILL" 0,
        "wght" 400,
        "GRAD" 0,
        "opsz" 24;
    }
    .star-icon {
      color: #cbd5e1; /* Gris por defecto */
      transition:
        color 0.2s,
        font-variation-settings 0.2s;
    }
    .star-icon.filled {
      font-variation-settings: "FILL" 1;
      color: #facc15; /* Amarillo cuando está activa */
    }
    .rating-btn.active-rating .rating-number {
      background-color: #3b82f6; /* Azul para el número seleccionado */
      color: white;
      padding: 2px 8px;
      border-radius: 8px;
    }
    .rating-btn {
      transition: all 0.2s;
      border-radius: 12px;
      padding: 8px;
    }
    .rating-btn.hover-active {
      background-color: rgba(59, 130, 246, 0.1);
    }
  </style>
  <!-- Modal Container -->
  <div
    class="relative w-full max-w-md overflow-hidden rounded-xl bg-white shadow-2xl border border-slate-200/50"
  >
    <!-- Header with Close Button -->
    <div
      class="flex items-center justify-between border-b border-slate-100 px-6 py-4"
    >
      <div class="flex items-center gap-2 text-blue-500">
        <span class="material-symbols-outlined">stars</span>
        <h2 class="text-slate-900 text-sm font-bold uppercase tracking-wider">
          Valoración
        </h2>
      </div>
      <button
        id="close-modal-btn"
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-500 hover:bg-blue-500 hover:text-white transition-colors"
      >
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
    </div>
    <!-- Content -->
    <div class="p-8 flex flex-col items-center text-center">
      <!-- Business Info -->
      <div class="mb-6">
        <h3
          class="text-2xl font-bold text-slate-900"
          id="nombre-establecimiento"
        >
        </h3>
        <p class="text-slate-500 font-medium" id="servicio"></p>
      </div>
      <div class="w-full h-px bg-slate-100 mb-8"></div>
      <h4 class="text-lg font-semibold text-slate-800 mb-6">
        ¿Qué te pareció el servicio?
      </h4>
      <!-- Rating Stars -->
      <div id="rating-container" class="flex items-center gap-3 mb-10">
        {
          [1, 2, 3, 4, 5].map((num) => (
            <button
              class="rating-btn group flex flex-col items-center gap-2"
              data-rating={num}
            >
              <div class="p-1">
                <span class="material-symbols-outlined text-4xl star-icon">
                  star
                </span>
              </div>
              <span class="rating-number text-xs font-bold text-slate-400 italic transition-all">
                {num}
              </span>
            </button>
          ))
        }
      </div>
      <!-- Action Buttons -->
      <div class="flex flex-col w-full gap-3">
        <button
          id="btn-enviar-valoracion"
          class="flex h-12 w-full items-center justify-center rounded-lg bg-primary text-black text-base font-bold shadow-lg shadow-blue-500 hover:bg-blue-500 hover:text-white transition-all active:scale-[0.98] border border-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          Enviar valoración
        </button>
        <button
          id="btn-omitir-valoracion"
          class="flex h-12 w-full items-center justify-center rounded-lg bg-slate-100 text-slate-600 text-base font-semibold hover:text-black hover:bg-red-500 transition-all active:scale-[0.98]"
        >
          Omitir
        </button>
      </div>
      <p class="mt-6 text-xs text-slate-400">
        Tu opinión nos ayuda a mejorar la experiencia.
      </p>
    </div>
  </div>
</div>

<script src="../utils/BodyNotificacion.js"></script>
