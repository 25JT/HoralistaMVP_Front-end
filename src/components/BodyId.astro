<main class="min-h-screen bg-[#f8fafc] pt-24 pb-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto space-y-8">
    <!-- Header Section -->
    <header class="flex flex-col gap-2">
      <h1
        id="nombre-negocio-titulo"
        class="text-slate-900 text-3xl md:text-5xl font-black leading-tight tracking-tight"
      >
        Agendar en
      </h1>
      <div class="h-1.5 w-24 bg-blue-500 rounded-full"></div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Info Sidebar -->
      <aside class="lg:col-span-4 space-y-6">
        <!-- Work Days Card -->
        <section
          class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4"
        >
          <div class="flex items-center gap-2 text-slate-800">
            <span class="material-symbols-outlined text-blue-500"
              >calendar_month</span
            >
            <h2 class="font-bold text-lg">Horario Semanal</h2>
          </div>
          <div id="contenedor-dias" class="grid grid-cols-7 gap-1">
            <!-- Days circles will be updated by JS -->
            {
              ["L", "M", "M", "J", "V", "S", "D"].map((day, i) => (
                <div
                  class="dia-circle flex flex-col items-center gap-1"
                  data-day={
                    [
                      "Lunes",
                      "Martes",
                      "Miercoles",
                      "Jueves",
                      "Viernes",
                      "Sabado",
                      "Domingo",
                    ][i]
                  }
                >
                  <div class="w-9 h-9 rounded-xl bg-slate-100 text-slate-400 flex items-center justify-center text-xs font-bold transition-all border border-transparent">
                    {day}
                  </div>
                </div>
              ))
            }
          </div>
          <div
            class="pt-4 flex flex-col gap-2 text-xs font-medium text-slate-500 border-t border-slate-100"
          >
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-blue-500"></div>
              <span>Atención disponible</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-slate-200"></div>
              <span>No laborable</span>
            </div>
          </div>
        </section>

        <!-- Special Dates Card -->
        <section
          class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4"
        >
          <div class="flex items-center gap-2 text-slate-800">
            <span class="material-symbols-outlined text-blue-500"
              >event_note</span
            >
            <h2 class="font-bold text-lg">Fechas Especiales</h2>
          </div>
          <div
            id="fechas-especiales"
            class="space-y-3 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar"
          >
            <!-- Populated by JS -->
          </div>
        </section>
      </aside>

      <!-- Booking Form -->
      <div class="lg:col-span-8">
        <div
          class="bg-white rounded-2xl shadow-xl shadow-blue-900/5 border border-slate-200 overflow-hidden"
        >
          <form id="citaForm" class="p-6 md:p-8 space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Date Selection -->
              <div class="space-y-3">
                <label
                  for="fecha"
                  class="block text-sm font-bold text-slate-700"
                >
                  Paso 1: Selecciona la Fecha
                </label>
                <div class="relative group">
                  <span
                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors z-10"
                  >
                    event
                  </span>
                  <input
                    id="fecha"
                    class="w-full h-14 pl-12 pr-4 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium"
                    placeholder="Toca para elegir fecha"
                    readonly
                  />
                </div>
              </div>

              <!-- Extra Info (Optional/Dynamic) -->
              <div class="flex flex-col justify-end">
                <p class="text-sm text-slate-500 italic leading-relaxed">
                  * Las horas disponibles se mostrarán automáticamente al
                  seleccionar una fecha válida.
                </p>
              </div>
            </div>

            <!-- Time Selection -->
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <label class="text-sm font-bold text-slate-700">
                  Paso 2: Elige tu Horario
                </label>
                <span
                  id="label-horario-seleccionado"
                  class="text-xs font-bold text-blue-500 bg-blue-50 px-3 py-1 rounded-full hidden"
                >
                  Hora: --:--
                </span>
              </div>

              <div id="loader-servicios" class="hidden justify-center py-12">
                <span class="loader border-blue-500 border-b-transparent"
                ></span>
              </div>

              <div
                id="horas"
                class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3"
              >
                <!-- Horas generated by JS -->
                <div
                  class="col-span-full text-center py-8 text-slate-400 border-2 border-dashed border-slate-100 rounded-xl"
                >
                  Selecciona una fecha primero
                </div>
              </div>
            </div>

            <!-- Notes Section -->
            <div class="space-y-3">
              <label
                for="mensaje"
                class="flex justify-between items-center text-sm font-bold text-slate-700"
              >
                Paso 3: Notas Adicionales
                <span class="text-xs font-normal text-slate-400"
                  ><span id="contador-mensaje">100</span> caracteres</span
                >
              </label>
              <textarea
                id="mensaje"
                rows="3"
                class="w-full p-4 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 resize-none"
                placeholder="¿Tienes alguna preferencia o comentario?"
              ></textarea>
            </div>

            <!-- Hidden Hora Input -->
            <input type="hidden" id="hora" name="hora" />

            <!-- Footer Buttons -->
            <footer
              class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-6 border-t border-slate-100"
            >
              <button
                id="volver"
                type="button"
                class="w-full sm:w-auto px-8 py-4 rounded-xl text-slate-600 font-bold hover:bg-slate-100 transition-all active:scale-95"
              >
                Cancelar
              </button>
              <button
                type="submit"
                class="w-full sm:w-auto px-10 py-4 bg-blue-500 text-white font-bold rounded-xl shadow-lg shadow-blue-200 hover:bg-blue-700 hover:shadow-xl hover:shadow-blue-300 transition-all active:scale-95 flex items-center justify-center gap-2"
              >
                <span class="material-symbols-outlined text-xl"
                  >check_circle</span
                >
                Confirmar Cita
              </button>
            </footer>
          </form>
        </div>
      </div>
    </div>
  </div>
  <!-- Modal de Registro / Login para invitados -->
  <div
    id="modal-registro-invitado"
    class="fixed inset-0 z-50 hidden items-start sm:items-center justify-center bg-slate-900/60 backdrop-blur-sm px-4 overflow-y-auto py-4"
  >
    <div
      class="w-full max-w-md bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden animate-slideUp my-auto"
    >
      <!-- ======= PANEL REGISTRO ======= -->
      <div id="panel-registro">
        <!-- Header registro -->
        <div class="bg-blue-500 px-8 pt-8 pb-10 relative">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="flex size-10 items-center justify-center rounded-xl bg-white/20"
            >
              <span class="material-symbols-outlined text-white text-xl"
                >person_add</span
              >
            </div>
            <h2 class="text-xl font-black text-white">Crea tu cuenta</h2>
          </div>
          <p class="text-blue-100 text-sm leading-relaxed">
            Para agendar tu cita necesitas registrarte. Solo te tomará un
            momento.
          </p>
          <div
            class="absolute -bottom-5 left-0 right-0 h-10 bg-white rounded-t-[2rem]"
          >
          </div>
        </div>

        <!-- Cuerpo registro -->
        <div class="px-8 pt-4 pb-8 space-y-5">
          <!-- Nombre -->
          <div class="space-y-1.5">
            <label
              for="reg-nombre"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Nombre</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                >person</span
              >
              <input
                id="reg-nombre"
                type="text"
                autocomplete="given-name"
                placeholder="¿Cómo te llamas?"
                class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
              />
            </div>
          </div>

          <!-- Teléfono con prefijo (custom dropdown) -->
          <div class="space-y-1.5">
            <label
              for="reg-telefono"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Teléfono</label
            >
            <div class="flex gap-2">
              <!-- Botón selector de país -->
              <div class="relative shrink-0">
                <button
                  type="button"
                  id="reg-cp-btn"
                  class="h-full px-3 flex items-center gap-1.5 text-sm rounded-xl border border-slate-200 bg-slate-50 hover:bg-slate-100 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none cursor-pointer whitespace-nowrap"
                >
                  <img
                    id="reg-cp-flag"
                    src="https://flagcdn.com/w20/co.png"
                    alt="CO"
                    class="w-5 h-auto rounded-sm"
                  />
                  <span
                    id="reg-cp-code"
                    class="text-sm font-semibold text-slate-800">+57</span
                  >
                  <svg
                    class="w-3 h-3 text-slate-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <!-- Lista desplegable -->
                <ul
                  id="reg-cp-list"
                  class="hidden absolute z-50 top-full left-0 mt-1 w-44 bg-white border border-slate-200 rounded-xl shadow-xl overflow-hidden"
                >
                  <li
                    data-iso="co"
                    data-code="+57"
                    class="flex items-center gap-2 px-3 py-2.5 hover:bg-blue-50 cursor-pointer text-sm"
                  >
                    <img
                      src="https://flagcdn.com/w20/co.png"
                      alt="CO"
                      class="w-5 h-auto rounded-sm"
                    />
                    <span class="font-semibold text-slate-800">+57</span>
                    <span class="text-slate-400 text-xs">Colombia</span>
                  </li>
                  <li
                    data-iso="cl"
                    data-code="+56"
                    class="flex items-center gap-2 px-3 py-2.5 hover:bg-blue-50 cursor-pointer text-sm"
                  >
                    <img
                      src="https://flagcdn.com/w20/cl.png"
                      alt="CL"
                      class="w-5 h-auto rounded-sm"
                    />
                    <span class="font-semibold text-slate-800">+56</span>
                    <span class="text-slate-400 text-xs">Chile</span>
                  </li>
                  <li
                    data-iso="es"
                    data-code="+34"
                    class="flex items-center gap-2 px-3 py-2.5 hover:bg-blue-50 cursor-pointer text-sm"
                  >
                    <img
                      src="https://flagcdn.com/w20/es.png"
                      alt="ES"
                      class="w-5 h-auto rounded-sm"
                    />
                    <span class="font-semibold text-slate-800">+34</span>
                    <span class="text-slate-400 text-xs">España</span>
                  </li>
                  <li
                    data-iso="mx"
                    data-code="+52"
                    class="flex items-center gap-2 px-3 py-2.5 hover:bg-blue-50 cursor-pointer text-sm"
                  >
                    <img
                      src="https://flagcdn.com/w20/mx.png"
                      alt="MX"
                      class="w-5 h-auto rounded-sm"
                    />
                    <span class="font-semibold text-slate-800">+52</span>
                    <span class="text-slate-400 text-xs">México</span>
                  </li>
                </ul>
              </div>
              <!-- Input número -->
              <div class="relative group flex-1">
                <span
                  class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                  >phone</span
                >
                <input
                  id="reg-telefono"
                  type="tel"
                  autocomplete="tel-national"
                  placeholder="300 000 0000"
                  class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
                />
              </div>
            </div>
          </div>

          <!-- Correo registro -->
          <div class="space-y-1.5">
            <label
              for="reg-correo"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Correo electrónico</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                >mail</span
              >
              <input
                id="reg-correo"
                type="email"
                autocomplete="email"
                placeholder="tucorreo@ejemplo.com"
                class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
              />
            </div>
          </div>

          <!-- Contraseña registro -->
          <div class="space-y-1.5">
            <label
              for="reg-contrasena"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Contraseña</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                >lock</span
              >
              <input
                id="reg-contrasena"
                type="password"
                autocomplete="new-password"
                placeholder="Mínimo 6 caracteres"
                class="w-full pl-12 pr-12 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
              />
              <button
                type="button"
                id="toggle-pwd-reg"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors"
                tabindex="-1"
              >
                <span
                  class="material-symbols-outlined text-xl"
                  id="icon-toggle-pwd">visibility</span
                >
              </button>
            </div>
          </div>

          <!-- Botón Registrarse -->
          <button
            id="btn-registro-invitado"
            type="button"
            class="w-full flex items-center justify-center gap-2 py-4 bg-white hover:bg-blue-600 hover:text-white active:scale-[0.98] border-2 border-blue-500 font-bold rounded-xl shadow-lg shadow-blue-200 transition-all text-sm"
          >
            <span
              class="text-blue-500 hover:text-white material-symbols-outlined text-lg"
              >check_circle</span
            >
            Crear cuenta y continuar
          </button>

          <!-- Divider -->
          <div class="flex items-center gap-3">
            <div class="flex-1 h-px bg-slate-100"></div>
            <span class="text-xs text-slate-400 font-medium">o</span>
            <div class="flex-1 h-px bg-slate-100"></div>
          </div>

          <!-- Botón ir a Login -->
          <button
            id="btn-login-invitado"
            type="button"
            class="w-full flex items-center justify-center gap-2 py-2.5 border border-slate-200 bg-white hover:bg-slate-50 active:scale-[0.98] text-slate-700 font-bold rounded-xl transition-all !text-xl"
          >
            <span class="material-symbols-outlined text-lg text-blue-500"
              >login</span
            >
            Ya tengo cuenta — Iniciar sesión
          </button>
        </div>
      </div>

      <!-- ======= PANEL LOGIN ======= -->
      <div id="panel-login" class="hidden">
        <!-- Header login -->
        <div class="bg-blue-500 px-8 pt-8 pb-10 relative">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="flex size-10 items-center justify-center rounded-xl bg-white/20"
            >
              <span class="material-symbols-outlined text-white text-xl"
                >login</span
              >
            </div>
            <h2 class="text-xl font-black text-white">Iniciar sesión</h2>
          </div>
          <p class="text-slate-300 text-sm leading-relaxed">
            Ingresa con tu cuenta para continuar con la reserva.
          </p>
          <div
            class="absolute -bottom-5 left-0 right-0 h-10 bg-white rounded-t-[2rem]"
          >
          </div>
        </div>

        <!-- Cuerpo login -->
        <div class="px-8 pt-4 pb-8 space-y-5">
          <!-- Correo login -->
          <div class="space-y-1.5">
            <label
              for="login-correo"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Correo electrónico</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                >mail</span
              >
              <input
                id="login-correo"
                type="email"
                autocomplete="email"
                placeholder="tucorreo@ejemplo.com"
                class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
              />
            </div>
          </div>

          <!-- Contraseña login -->
          <div class="space-y-1.5">
            <label
              for="login-contrasena"
              class="block text-xs font-bold uppercase tracking-wider text-slate-500"
              >Contraseña</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors text-xl"
                >lock</span
              >
              <input
                id="login-contrasena"
                type="password"
                autocomplete="current-password"
                placeholder="Tu contraseña"
                class="w-full pl-12 pr-12 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none text-slate-900 font-medium text-sm"
              />
              <button
                type="button"
                id="toggle-pwd-login"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors"
                tabindex="-1"
              >
                <span
                  class="material-symbols-outlined text-xl"
                  id="icon-toggle-pwd-login">visibility</span
                >
              </button>
            </div>
          </div>

          <!-- Botón Iniciar sesión -->
          <button
            id="btn-submit-login"
            type="button"
            class="w-full flex items-center justify-center gap-2 py-4 bg-blue-500 hover:bg-blue-600 active:scale-[0.98] text-white font-bold rounded-xl shadow-lg shadow-blue-200 transition-all !text-xl"
          >
            <span class="material-symbols-outlined text-lg">login</span>
            Ingresar
          </button>

          <!-- Divider -->
          <div class="flex items-center gap-3">
            <div class="flex-1 h-px bg-slate-100"></div>
            <span class="text-xs text-slate-400 font-medium">o</span>
            <div class="flex-1 h-px bg-slate-100"></div>
          </div>

          <!-- Botón volver a registro -->
          <button
            id="btn-volver-registro"
            type="button"
            class="w-full flex items-center justify-center gap-2 py-3.5 border border-slate-200 bg-white hover:bg-slate-50 active:scale-[0.98] text-slate-700 font-bold rounded-xl transition-all !text-xl"
          >
            <span class="material-symbols-outlined text-lg text-slate-400"
              >arrow_back</span
            >
            Volver — Crear una cuenta
          </button>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  /* Loader Styles */
  .loader {
    width: 32px;
    height: 32px;
    border: 3px solid #e2e8f0;
    border-bottom-color: transparent;
    border-radius: 50%;
    display: inline-block;
    box-sizing: border-box;
    animation: rotation 1s linear infinite;
  }

  @keyframes rotation {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  /* Animations */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  #citaForm > * {
    animation: slideUp 0.5s ease-out forwards;
  }

  @keyframes modalSlideUp {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .animate-slideUp {
    animation: modalSlideUp 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
