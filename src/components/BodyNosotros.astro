<script src="../assets/Animaciones/animaNosotros.js"></script>
<script>
  (function () {
    const slides = document.querySelectorAll("#carousel .carousel-slide");
    const dots = document.querySelectorAll("#carousel .carousel-dot");
    let current = 0;

    function goTo(index) {
      slides[current].classList.replace("opacity-100", "opacity-0");
      dots[current].classList.replace("opacity-100", "opacity-40");
      current = index;
      slides[current].classList.replace("opacity-0", "opacity-100");
      dots[current].classList.replace("opacity-40", "opacity-100");
    }

    dots.forEach((dot) =>
      dot.addEventListener("click", () => goTo(+dot.dataset.index)),
    );
    setInterval(() => goTo((current + 1) % slides.length), 3000);
  })();
</script>
